\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3896, 'mesSvrID': 5913523586428312480, 'msgCreateTime': 1663767227, 'msgContent': '这有什么不可信的', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3897, 'mesSvrID': 2673166813657974524, 'msgCreateTime': 1663767311, 'msgContent': '如果连这点都不可信，我做的反思也都看不见，那我还有什么话可说呢', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3898, 'mesSvrID': 4845861483502770142, 'msgCreateTime': 1663767520, 'msgContent': '另外我留着你不删其实跟你那个34岁男的想法是一样的，没有删人的习惯，江湖来往，往往都是相逢一笑泯恩仇的事，我没必要把自己的路越走越窄，但这并非是你可以一次次提什么拉黑的理由，因为首先我觉得我有足够的诚意，其次也给予了你一点补偿（其实准确地说是承诺，尽管是以其他名义），我自己是问心无愧的', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3899, 'mesSvrID': 7804096946802857230, 'msgCreateTime': 1663767634, 'msgContent': '一开始的真诚、后来的误会与走极端、到最后的互相谅解与新型关系的尝试，我觉得这一切都是很顺利成章的，我并不清楚你现在执着的点是什么', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3900, 'mesSvrID': 3432569934809463302, 'msgCreateTime': 1663767785, 'msgContent': '最后，如果你硬要掰扯的话', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3901, 'mesSvrID': 1047437047722222562, 'msgCreateTime': 1663767794, 'msgContent': '我建议你仔细复盘一下你来之前我们的一些对话', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3902, 'mesSvrID': 2858289431289760379, 'msgCreateTime': 1663767827, 'msgContent': '我对你做那么粗鲁的事，确实是我不对，这点我表示道歉，也不符合我的素养，我以后也不会做这么傻逼的事', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3903, 'mesSvrID': 8651174710275003594, 'msgCreateTime': 1663767958, 'msgContent': '但你真地就对这个大家都不愿看到的事情的发生没有一点责任吗，多余的我也没有必要展开了，否则显得我咄咄逼人、锱铢必较，我还是觉得我们可以做很好的朋友的，这点之前就已经分析过了，我们都不是那么沉不住气、受不住气的人，但我希望我们之间的关系是平等的，谢谢', 'msgStatus': 2, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 0, 'msgSource': '<msgsource></msgsource>', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802393, 'ConBlob': b'r\x13wxid_ck85xup8b1bj21z\x13wxid_bpxdh179fsgs22\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3904, 'mesSvrID': 6612127979584393994, 'msgCreateTime': 1663768246, 'msgContent': '我日', 'msgStatus': 4, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 1, 'msgSource': '<msgsource>\n\t<signature>v1_MapGt0Yj</signature>\n</msgsource>\n', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802460, 'ConBlob': b'r\x13wxid_bpxdh179fsgs22z\x13wxid_ck85xup8b1bj21\x92\x01\x12\xe9\x99\x88\xe6\x99\xb6\xe6\x95\x8f : \xe6\x88\x91\xe6\x97\xa5\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3905, 'mesSvrID': 7975127403108598549, 'msgCreateTime': 1663768263, 'msgContent': '我还沉浸在今天和小哥哥牵手的幸福里，你搁这长篇大论', 'msgStatus': 4, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 1, 'msgSource': '<msgsource>\n\t<signature>v1_QaJ312n2</signature>\n</msgsource>\n', 'IntRes1': 0, 'IntRes2': 0, 'StrRes1': None, 'StrRes2': None, 'msgVoiceText': None, 'msgSeq': 755802461, 'ConBlob': b'r\x13wxid_bpxdh179fsgs22z\x13wxid_ck85xup8b1bj21\x92\x01W\xe9\x99\x88\xe6\x99\xb6\xe6\x95\x8f : \xe6\x88\x91\xe8\xbf\x98\xe6\xb2\x89\xe6\xb5\xb8\xe5\x9c\xa8\xe4\xbb\x8a\xe5\xa4\xa9\xe5\x92\x8c\xe5\xb0\x8f\xe5\x93\xa5\xe5\x93\xa5\xe7\x89\xb5\xe6\x89\x8b\xe7\x9a\x84\xe5\xb9\xb8\xe7\xa6\x8f\xe9\x87\x8c\xef\xbc\x8c\xe4\xbd\xa0\xe6\x90\x81\xe8\xbf\x99\xe9\x95\xbf\xe7\xaf\x87\xe5\xa4\xa7\xe8\xae\xba\x80\x01\x00\x98\x01\x00\xa0\x01\x00\xb8\x01\x00\xc8\x01\x00\xd0\x01\x00\xf0\x01\x00\xf8\x01\x00'}, {'mesLocalID': 3906, 'mesSvrID': 2680555606843235441, 'msgCreateTime': 1663768271, 'msgContent': '🆘', 'msgStatus': 4, 'msgImgStatus': 1, 'messageType': 1, 'mesDes': 1, 'msgSource': '<msgsour